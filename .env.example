# ─── FoodPoint — Variáveis de Ambiente ─────────────────────────────────────────
# Copie este arquivo para ".env" e ajuste os valores.
# Nunca suba o arquivo ".env" para o repositório (já está no .gitignore).

# URL base da API Node.js/Express conectada ao MySQL
VITE_API_URL=http://localhost:3001/api

# Modo mock: "true" usa dados locais (sem backend), "false" usa a API real
# Defina como "false" quando o backend estiver rodando
VITE_USE_MOCK=true

# ─── Rotas esperadas no backend ─────────────────────────────────────────────────
#
# Auth
# POST   /auth/login                   { email, senha, tipo }  → { user, token }
# POST   /auth/register/client         { nome, cpf, telefone, email, senha, cidade, uf }
# POST   /auth/register/seller         { nome_responsavel, cpf_cnpj, tipo_documento,
#                                         nome_empresa, tipo_negocio, telefone, email,
#                                         bairro, cidade, uf, instagram, chave_pix,
#                                         tipo_chave_pix, descricao_loja, senha }
#
# Vendedores
# GET    /vendedores?tipo_negocio=&search=   → vendedor[]
# GET    /vendedores/:id                     → vendedor
# PUT    /vendedores/:id                     → vendedor atualizado
#
# Produtos  (retornam dados da view vw_estoque quando possível)
# GET    /produtos?vendedor_id=   → produto[]
# POST   /produtos                → produto criado
# PUT    /produtos/:id            → produto atualizado
# DELETE /produtos/:id
#
# Pedidos
# POST   /pedidos                 { cliente_id, vendedor_id, tipo_entrega, horario_retirada,
#                                   total, metodo_pagamento, observacoes, itens[] }
# GET    /pedidos?vendedor_id=    → pedido[]
# GET    /pedidos?cliente_id=     → pedido[]
# PUT    /pedidos/:id/status      { status }
#
# Chat
# POST   /conversas               { cliente_id, vendedor_id }
# GET    /conversas?cliente_id=   → conversa[]
# GET    /conversas?vendedor_id=  → conversa[]
# GET    /conversas/:id/mensagens → mensagem[]
# POST   /mensagens               { conversa_id, remetente_tipo, remetente_id, conteudo }
#
# Avaliações
# POST   /avaliacoes              { cliente_id, vendedor_id, pedido_id, estrelas, comentario }
# GET    /avaliacoes?vendedor_id= → avaliacao[]
