# ─── FoodPoint — Backend ───────────────────────────────────────────────────────
# Copie este arquivo para "backend/.env" e preencha os valores

# Banco de dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=foodpoint

# JWT — gere um valor aleatório seguro (ex: openssl rand -hex 32)
JWT_SECRET=

# Servidor
PORT=3001
FRONTEND_URL=http://localhost:5173

# Gmail — para recuperação de senha
# Use uma "Senha de App" gerada em: myaccount.google.com/apppasswords
GMAIL_USER=seuemail@gmail.com
GMAIL_APP_PASSWORD=

# Stripe — pagamentos com cartão
# Chave secreta (começa com sk_test_ ou sk_live_)
STRIPE_SECRET_KEY=sk_test_...
# Webhook secret gerado no Stripe Dashboard
STRIPE_WEBHOOK_SECRET=whsec_...
